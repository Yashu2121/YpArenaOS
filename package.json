{
  "name": "yp-arena-os-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "YP Arena OS Monorepo for Client, Server Engine, and Dashboard",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=apps/landing-page && node -e \"require('fs').cpSync('apps/landing-page/dist', 'dist', {recursive: true})\"",
    "dev:all": "npm run dev --workspaces --if-present",
    "build:all": "npm run build --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present"
  }
}
