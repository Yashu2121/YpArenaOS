    "@types/react": "^18",
    "@types/react-dom": "^18",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-serve": "^3.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
