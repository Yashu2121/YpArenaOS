{
  "name": "yp-arena-os-pc-client",
  "version": "1.0.0",
  "description": "Secure PC client kiosk shell launcher for YP Arena OS",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.yp-arena-os.kioskclient",
    "productName": "YP Arena OS Client",
    "publish": [],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "dist/**/*",
      "main.js",
      "watchdog.js"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release-builds"
    }
  }
}
